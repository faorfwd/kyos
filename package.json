{
  "name": "kyos-cli",
  "version": "1.1.1",
  "description": "Bootstrap and safely evolve a shared Claude Code repo structure.",
  "author": "Eugene",
  "keywords": [
    "claude",
    "bootstrap",
    "cli",
    "kyos",
    "mcp",
    "supply-chain",
    "zero-dependencies",
    "npm-provenance"
  ],
  "license": "MIT",
  "homepage": "https://github.com/ajesskit/kyos#readme",
  "bugs": {
    "url": "https://github.com/ajesskit/kyos/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ajesskit/kyos.git"
  },
  "bin": {
    "kyos-cli": "bin/kyos.js",
    "kyos": "bin/kyos.js"
  },
  "files": [
    "bin/",
    "catalog/",
    "src/",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "start": "node ./bin/kyos.js --init",
    "test": "node ./test/run.js",
    "lint": "eslint src/ bin/",
    "prepublishOnly": "npm run lint && npm test && npm pack --dry-run",
    "prepack": "npm test",
    "pack:check": "npm pack --dry-run",
    "release": "node scripts/release.js"
  },
  "engines": {
    "node": ">=18",
    "npm": ">=9"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.1"
  }
}
